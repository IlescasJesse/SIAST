// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Rol {
  ADMIN
  TECNICO_TI
  TECNICO_REDES
  TECNICO_SERVICIOS
  MESA_AYUDA
  GESTOR_RECURSOS_MATERIALES
  EMPLEADO
}

enum CategoriaTicket {
  TECNOLOGIAS
  SERVICIOS
  RECURSOS_MATERIALES
}

enum SubcategoriaTicket {
  // Categoría: TECNOLOGIAS
  SISTEMAS_INSTITUCIONALES
  EQUIPOS_DISPOSITIVOS
  RED_INTERNET
  CUENTAS_DOMINIO
  CORREO_OUTLOOK
  // Categoría: SERVICIOS
  SANITARIOS
  ILUMINACION
  MOVILIDAD
  // Categoría: RECURSOS_MATERIALES
  SALA_JUNTAS
  EQUIPO_AUDIOVISUAL
  PRESTAMO_EQUIPO
  MOBILIARIO
  PAPELERIA
}

enum EstadoTicket {
  ABIERTO
  ASIGNADO
  EN_PROGRESO
  RESUELTO
  CANCELADO
}

enum PrioridadTicket {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum PisoEdificio {
  PB       // Planta Baja — floor: 0
  NIVEL_1  // floor: 1
  NIVEL_2  // floor: 2
  NIVEL_3  // floor: 3
}

enum TipoNotificacion {
  TICKET_CREADO
  TICKET_ASIGNADO
  TICKET_ACTUALIZADO
  TICKET_RESUELTO
  TICKET_CANCELADO
  TICKET_URGENTE
}

enum TipoRecurso {
  TECNOLOGICO
  INMOBILIARIO
}

enum EstadoAsignacion {
  PENDIENTE
  APROBADA
  RECHAZADA
  DEVUELTA
}

// ============================================================
// USUARIOS DEL SISTEMA (Staff: Admin, Técnicos, Mesa de Ayuda)
// ============================================================

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.VarChar(100)
  apellidos String   @db.VarChar(150)
  usuario   String   @unique @db.VarChar(50)
  password  String   @db.VarChar(255) // bcrypt hash
  email     String?  @db.VarChar(200)
  telefono  String?  @db.VarChar(20)
  rol       Rol
  activo    Boolean  @default(true)
  permisos  Json?    // permisos adicionales u overrides sobre los defaults del rol

  // Vinculación con empleado de estructura (SIRH)
  esEmpleadoEstructura Boolean @default(false)
  empleadoId           String? @unique @db.VarChar(24) // _id de MongoDB en SIRH
  rfc                  String? @unique @db.VarChar(13) // RFC del empleado en SIRH

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  ticketsAsignados   Ticket[]            @relation("TecnicoAsignado")
  ticketsCreados     Ticket[]            @relation("UsuarioCreador")
  comentarios        Comentario[]
  historialAcciones  HistorialTicket[]
  notificaciones     Notificacion[]
  asignacionesGestor AsignacionRecurso[] @relation("GestorAsignaciones")
  pasosAsignados     PasoTicket[]        @relation("TecnicoPaso")
  sesiones           Sesion[]
  logsAcceso         LogAcceso[]

  @@index([rol])
  @@index([activo])
  @@map("usuarios")
}

// ============================================================
// EMPLEADOS (del SIRH — quienes abren tickets con su RFC)
// ============================================================

model Empleado {
  id             Int          @id @default(autoincrement())
  rfc            String       @unique @db.VarChar(13)
  nombre         String       @db.VarChar(100)
  apellidos      String       @db.VarChar(150)
  nombreCompleto String       @db.VarChar(255) // computed on save: nombre + apellidos
  email          String?      @db.VarChar(200)
  departamento   String?      @db.VarChar(150)
  puesto         String?      @db.VarChar(150)
  // Datos del SIRH adicionales
  adscripcion    String?      @db.VarChar(200) // ej: "SECRETARÍA DE FINANZAS Y ADMINISTRACIÓN"

  telefono       String?      @db.VarChar(20) // celular para OTP (se registra en primer acceso)
  primerAcceso   Boolean      @default(true)  // true hasta que el empleado confirma su teléfono
  fechaUltimoAcceso DateTime?                 // última vez que inició sesión

  // Datos extendidos del SIRH
  sirhId         String?      @unique @db.VarChar(24) // _id de MongoDB en SIRH
  curp           String?      @db.VarChar(18)
  numEmpleado    Int?                                  // NUMEMP
  numPlaza       Int?                                  // NUMPLA
  nivel          String?      @db.VarChar(10)          // ej: "03A"
  fechaIngreso   DateTime?                             // FECHA_INGRESO
  grupoSangre    String?      @db.VarChar(10)          // ej: "ORH+"
  sexo           String?      @db.VarChar(1)           // "H" o "M"
  // Vacaciones (resumen del periodo activo)
  vacacionesPeriodo Int?                               // VACACIONES.PERIODO
  vacacionesFecha   String?   @db.VarChar(20)          // VACACIONES.FECHA_VACACIONES

  // Ubicación física en el edificio
  areaId         String       @db.VarChar(100) // ej: "n2_informatica"
  piso           PisoEdificio
  activo         Boolean      @default(true)
  sincronizadoSIRH Boolean   @default(false) // true si vino de SIRH
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // Relaciones
  area                AreaEdificio        @relation(fields: [areaId], references: [id])
  tickets             Ticket[]
  notificaciones      Notificacion[]
  asignacionesRecurso AsignacionRecurso[]
  sesiones            Sesion[]
  logsAcceso          LogAcceso[]

  @@index([rfc])
  @@index([areaId])
  @@index([piso])
  @@map("empleados")
}

// ============================================================
// OTP TOKENS (autenticación de empleados vía WhatsApp/SMS)
// ============================================================

model OtpToken {
  id        Int      @id @default(autoincrement())
  rfc       String   @db.VarChar(13)
  codigo    String   @db.VarChar(6)
  usado     Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([rfc])
  @@map("otp_tokens")
}

// ============================================================
// ÁREAS DEL EDIFICIO (extraídas de los planos arquitectónicos)
// ============================================================

model AreaEdificio {
  id    String       @id @db.VarChar(100) // ej: "n2_informatica"
  label String       @db.VarChar(200) // ej: "Informática"
  piso  PisoEdificio
  floor Int // 0=PB, 1, 2, 3

  // Coordenadas en la cuadrícula del plano (32x27)
  gridX1 Int? // columna inicio
  gridY1 Int? // fila inicio
  gridX2 Int? // columna fin
  gridY2 Int? // fila fin

  // Vinculación con adscripción SIRH (opcional, asignada desde el editor)
  adscripcionNombre String? @db.VarChar(200)
  adscripcionNivel  Int?

  esSalaJuntas Boolean @default(false)

  activo Boolean @default(true)

  // Relaciones
  empleados Empleado[]
  tickets   Ticket[]

  @@index([piso])
  @@index([floor])
  @@map("areas_edificio")
}

// ============================================================
// TICKETS
// ============================================================

model Ticket {
  id           Int                @id @default(autoincrement())
  folio        String             @unique @db.VarChar(20)
  asunto       String             @db.VarChar(100)
  descripcion  String             @db.Text
  categoria    CategoriaTicket
  subcategoria SubcategoriaTicket
  estado       EstadoTicket       @default(ABIERTO)
  prioridad    PrioridadTicket    @default(MEDIA)

  // Empleado que reporta
  empleadoRfc String   @db.VarChar(13)
  empleado    Empleado @relation(fields: [empleadoRfc], references: [rfc])

  // Ubicación del problema
  areaId String       @db.VarChar(100)
  area   AreaEdificio @relation(fields: [areaId], references: [id])
  piso   PisoEdificio

  // Usuario del sistema que creó (puede ser MESA_AYUDA creando por empleado)
  creadoPorId Int?
  creadoPor   Usuario? @relation("UsuarioCreador", fields: [creadoPorId], references: [id])

  // Técnico asignado
  tecnicoId Int?
  tecnico   Usuario? @relation("TecnicoAsignado", fields: [tecnicoId], references: [id])

  // Fechas clave
  fechaAsignacion DateTime?
  fechaInicio     DateTime? // cuando técnico marca "en progreso"
  fechaResolucion DateTime?

  // Recursos adicionales solicitados al crear el ticket (JSON serializado)
  // Ej: sala preferida, equipo audiovisual requerido, equipo para préstamo
  recursosAdicionales String? @db.Text

  // Subtipo dentro de EQUIPOS_DISPOSITIVOS (equipo nuevo, falla impresora, etc.)
  subTipo String? @db.VarChar(50) @map("sub_tipo")

  // Control
  activo    Boolean  @default(true) // false = eliminado (soft delete)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  historial           HistorialTicket[]
  comentarios         Comentario[]
  notificaciones      Notificacion[]
  asignacionesRecurso AsignacionRecurso[]
  pasos               PasoTicket[]

  @@index([estado])
  @@index([empleadoRfc])
  @@index([tecnicoId])
  @@index([categoria])
  @@index([piso])
  @@index([createdAt])
  @@index([activo])
  @@index([empleadoRfc, estado, activo])
  @@map("tickets")
}

// ============================================================
// HISTORIAL DE ESTADOS DEL TICKET
// ============================================================

model HistorialTicket {
  id             Int           @id @default(autoincrement())
  ticketId       Int
  ticket         Ticket        @relation(fields: [ticketId], references: [id])
  estadoAnterior EstadoTicket?
  estadoNuevo    EstadoTicket

  // Quién hizo el cambio
  usuarioId   Int?
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  empleadoRfc String?  @db.VarChar(13) // si el cambio lo hizo el empleado (ej: cancelar)

  comentario String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
  @@map("historial_tickets")
}

// ============================================================
// COMENTARIOS / SEGUIMIENTO
// ============================================================

model Comentario {
  id       Int    @id @default(autoincrement())
  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id])

  texto     String  @db.Text
  esInterno Boolean @default(false) // true = solo staff, false = visible al empleado

  usuarioId Int
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ticketId])
  @@map("comentarios")
}

// ============================================================
// NOTIFICACIONES
// ============================================================

model Notificacion {
  id      Int              @id @default(autoincrement())
  tipo    TipoNotificacion
  titulo  String           @db.VarChar(200)
  mensaje String           @db.Text
  leida   Boolean          @default(false)

  // Destinatario: puede ser usuario del sistema O empleado
  usuarioId   Int?
  usuario     Usuario?  @relation(fields: [usuarioId], references: [id])
  empleadoRfc String?   @db.VarChar(13)
  empleado    Empleado? @relation(fields: [empleadoRfc], references: [rfc])

  // Referencia al ticket relacionado
  ticketId Int?
  ticket   Ticket? @relation(fields: [ticketId], references: [id])

  createdAt DateTime @default(now())

  @@index([usuarioId, leida])
  @@index([empleadoRfc, leida])
  @@index([ticketId])
  @@map("notificaciones")
}

// ============================================================
// RECURSOS MATERIALES (salas, equipo tecnológico, mobiliario)
// ============================================================

// ── Catálogo de recursos (tipo/familia) ───────────────────────
model CatalogoRecurso {
  id          Int           @id @default(autoincrement())
  nombre      String        @db.VarChar(150)
  descripcion String?       @db.Text
  tipo        TipoRecurso
  marca       String?       @db.VarChar(100)
  capacidad        Int?          // Para inmobiliario/salas: aforo
  requiereHorario  Boolean       @default(false)

  // SICIPO — pendiente integración con sistema de inventario gubernamental
  // codigoSicipo String?  @db.VarChar(50)

  activo      Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  unidades    RecursoUnidad[]

  @@index([tipo])
  @@map("catalogo_recursos")
}

// ── Unidad física individual ───────────────────────────────────
model RecursoUnidad {
  id          Int              @id @default(autoincrement())
  catalogoId  Int
  catalogo    CatalogoRecurso  @relation(fields: [catalogoId], references: [id])

  numSerie    String?          @db.VarChar(100)

  // SICIPO — número de inventario codificado en código de barras — pendiente
  // codigoInventario String? @db.VarChar(100)

  piso        PisoEdificio?
  areaId      String?          @db.VarChar(100)

  disponible  Boolean          @default(true)
  activo      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  asignaciones AsignacionRecurso[]

  @@index([catalogoId])
  @@index([disponible, activo])
  @@map("unidades_recurso")
}

model AsignacionRecurso {
  id          Int              @id @default(autoincrement())

  unidadId    Int
  unidad      RecursoUnidad    @relation(fields: [unidadId], references: [id])

  ticketId    Int?
  ticket      Ticket?          @relation(fields: [ticketId], references: [id])

  empleadoRfc String?          @db.VarChar(13)
  empleado    Empleado?        @relation(fields: [empleadoRfc], references: [rfc])

  // Gestor que aprueba/asigna
  gestorId    Int?
  gestor      Usuario?         @relation("GestorAsignaciones", fields: [gestorId], references: [id])

  fechaInicio DateTime?
  fechaFin    DateTime?

  // Préstamo con salida del edificio
  saleDEdificio    Boolean  @default(false)
  propositoSalida  String?  @db.VarChar(300)
  ordenSalidaFolio String?  @db.VarChar(50)

  estado     EstadoAsignacion @default(PENDIENTE)
  comentario String?          @db.Text

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([unidadId])
  @@index([ticketId])
  @@index([empleadoRfc])
  @@index([estado])
  @@map("asignaciones_recursos")
}

// ============================================================
// SESIONES ACTIVAS (control de máx. 2 sesiones por usuario)
// ============================================================

model Sesion {
  id          Int      @id @default(autoincrement())
  jti         String   @unique @db.VarChar(36)   // UUID único por sesión
  usuarioId   Int?     @map("usuario_id")
  usuario     Usuario? @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empleadoRfc String?  @db.VarChar(13) @map("empleado_rfc")
  empleado    Empleado? @relation(fields: [empleadoRfc], references: [rfc], onDelete: Cascade)
  ipAddress   String?  @db.VarChar(45) @map("ip_address")
  userAgent   String?  @db.VarChar(300) @map("user_agent")
  activa      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")

  @@index([usuarioId])
  @@index([empleadoRfc])
  @@index([activa])
  @@map("sesiones")
}

// ============================================================
// LOGS DE ACCESO (intentos exitosos y fallidos)
// ============================================================

model LogAcceso {
  id          Int      @id @default(autoincrement())
  tipo        String   @db.VarChar(10)            // "STAFF" | "EMPLEADO"
  identifier  String   @db.VarChar(50)            // usuario o RFC
  resultado   String   @db.VarChar(30)            // "OK" | "FAIL_PASSWORD" | "FAIL_NOT_FOUND" | "FAIL_INACTIVE"
  usuarioId   Int?     @map("usuario_id")
  usuario     Usuario? @relation(fields: [usuarioId], references: [id])
  empleadoRfc String?  @db.VarChar(13) @map("empleado_rfc")
  empleado    Empleado? @relation(fields: [empleadoRfc], references: [rfc])
  ipAddress   String?  @db.VarChar(45) @map("ip_address")
  userAgent   String?  @db.VarChar(300) @map("user_agent")
  detalle     String?  @db.VarChar(200)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([usuarioId])
  @@index([resultado])
  @@map("logs_acceso")
}

// ============================================================
// PASOS DE FLUJO MULTI-TÉCNICO (tickets TI)
// ============================================================

model PasoTicket {
  id           Int       @id @default(autoincrement())
  ticketId     Int       @map("ticket_id")
  ticket       Ticket    @relation(fields: [ticketId], references: [id])
  orden        Int
  nombre       String?   @db.VarChar(150)
  rolRequerido String    @db.VarChar(50) @map("rol_requerido")
  tecnicoId    Int?      @map("tecnico_id")
  tecnico      Usuario?  @relation("TecnicoPaso", fields: [tecnicoId], references: [id])
  estado       String    @default("PENDIENTE") @db.VarChar(20)
  notas        String?   @db.Text
  cantidadUnidades Int?  @map("cantidad_unidades")
  labelUnidades String?  @db.VarChar(100) @map("label_unidades")
  completadoAt DateTime? @map("completado_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([ticketId])
  @@map("pasos_ticket")
}

// ============================================================
// DEFINICIÓN DE PROCESOS (plantillas de flujo multi-paso)
// ============================================================

model ProcesoDefinicion {
  id           Int                @id @default(autoincrement())
  subcategoria SubcategoriaTicket
  subTipo      String?            @db.VarChar(50) @map("sub_tipo")
  tipoFlujo    String             @db.VarChar(20) @map("tipo_flujo") // "DIRECTO" | "SECUENCIAL" | "PENDIENTE"
  nombre       String             @db.VarChar(150)
  descripcion  String?            @db.VarChar(300)
  activo       Boolean            @default(true)
  createdAt    DateTime           @default(now()) @map("created_at")
  pasos        PasoDefinicion[]

  @@unique([subcategoria, subTipo])
  @@map("procesos_definicion")
}

model PasoDefinicion {
  id               Int               @id @default(autoincrement())
  procesoId        Int               @map("proceso_id")
  proceso          ProcesoDefinicion @relation(fields: [procesoId], references: [id])
  orden            Int
  rolRequerido     String            @db.VarChar(50) @map("rol_requerido") // "TECNICO_TI" | "TECNICO_REDES"
  nombre           String            @db.VarChar(150)
  descripcion      String?           @db.VarChar(300)
  registraUnidades Boolean           @default(false) @map("registra_unidades") // true si el técnico registra una cantidad al completar
  labelUnidades    String?           @db.VarChar(100) @map("label_unidades") // ej: "PCs con impresora instalada"

  @@index([procesoId])
  @@map("pasos_definicion")
}
