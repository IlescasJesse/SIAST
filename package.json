{
  "name": "sistema-tickets-finanzas",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo MVP para sistema de tickets de finanzas",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:3d\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w ./apps/api",
    "dev:3d": "npm run dev -w ./apps/modelado-3d",
    "dev:web": "npm run dev -w ./apps/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write ."
  },
  "keywords": [
    "nextjs",
    "express",
    "tickets",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.6.2"
  }
}
