{
  "name": "sistema-tickets-finanzas",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo MVP para sistema de tickets de finanzas",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:3d\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w ./apps/api",
    "dev:3d": "npm run dev -w ./apps/modelado-3d",
    "dev:web": "node -e \"const fs=require('fs');const{spawn}=require('child_process');if(!fs.existsSync('apps/web/package.json')){console.log('apps/web no existe; saltando web');process.exit(0);}const npm=process.platform==='win32'?'npm.cmd':'npm';const p=spawn(npm,['run','dev','-w','./apps/web'],{stdio:'inherit'});p.on('exit',c=>process.exit(c??0));\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write ."
  },
  "keywords": [
    "nextjs",
    "express",
    "tickets",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.6.2"
  }
}
